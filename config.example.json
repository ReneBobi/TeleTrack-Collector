{
  "organization": {
    "id": "your-organization-id",
    "name": "Your Organization Name",
    "apiKey": "your-api-key-here"
  },
  "ami": {
    "host": "127.0.0.1",
    "port": 5038,
    "username": "your-ami-username",
    "password": "your-ami-password"
  },
  "cloud": {
    "endpoint": "https://teletrack.vercel.app/api/calls/ingest",
    "timeout": 30000,
    "retryAttempts": 3,
    "retryDelay": 5000
  },
  "collector": {
    "name": "main-collector",
    "heartbeatInterval": 60000,
    "batchSize": 10,
    "batchTimeout": 5000
  },
  "logging": {
    "level": "info",
    "file": "collector.log",
    "maxSize": "10MB",
    "maxFiles": 5
  }
}
